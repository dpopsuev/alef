{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"packages/*/src/**/*.ts",
			"packages/*/test/**/*.ts",
			"packages/coding-agent/examples/**/*.ts",
			"packages/ui/web/src/**/*.ts",
			"packages/ui/web/example/**/*.ts",
			"!**/node_modules/**/*",
			"!**/test-sessions.ts",
			"!**/models.generated.ts",
			"!packages/ui/web/src/app.css",
			"!packages/mom/data/**/*",
			"!!**/node_modules"
		]
	},
	"overrides": [
		{
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "error"
					},
					"suspicious": {
						"noExplicitAny": "error"
					},
					"nursery": {
						"noFloatingPromises": "error"
					}
				}
			},
			"includes": [
				"packages/kernel/src/**/*.ts",
				"packages/runtime/src/**/*.ts",
				"packages/tools/*/src/**/*.ts",
				"packages/runner/src/**/*.ts",
				"packages/eval/src/**/*.ts",
				"packages/testkit/src/**/*.ts"
			]
		}
	]
}
