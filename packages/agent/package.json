{
	"name": "@dpopsuev/alef",
	"version": "0.1.0",
	"description": "Minimal Alef agent runner \u2014 print mode and interactive stdin loop",
	"type": "module",
	"bin": {
		"alef": "bin/alef.js"
	},
	"files": [
		"dist",
		"bin",
		"README.md"
	],
	"scripts": {
		"start": "tsx src/cli/main.ts",
		"build": "npx tsc -p tsconfig.build.json",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit"
	},
	"dependencies": {
		"@dpopsuev/alef-adapter-agent": "workspace:*",
		"@dpopsuev/alef-adapter-code-intel": "workspace:*",
		"@dpopsuev/alef-adapter-discourse": "workspace:*",
		"@dpopsuev/alef-adapter-factory": "workspace:*",
		"@dpopsuev/alef-adapter-fs": "workspace:*",
		"@dpopsuev/alef-adapter-nodesh": "workspace:*",
		"@dpopsuev/alef-adapter-shell": "workspace:*",
		"@dpopsuev/alef-adapter-web": "workspace:*",
		"@dpopsuev/alef-adapter-workflow": "workspace:*",
		"@dpopsuev/alef-agent-blueprint": "workspace:*",
		"@dpopsuev/alef-coding-agent": "workspace:*",
		"@dpopsuev/alef-factory-agent": "workspace:*",
		"@dpopsuev/alef-gateway": "workspace:*",
		"@dpopsuev/alef-kernel": "workspace:*",
		"@dpopsuev/alef-llm": "workspace:*",
		"@dpopsuev/alef-meta": "workspace:*",
		"@dpopsuev/alef-reasoner": "workspace:*",
		"@dpopsuev/alef-runtime": "workspace:*",
		"@dpopsuev/alef-session": "workspace:*",
		"@dpopsuev/alef-storage": "workspace:*",
		"@dpopsuev/alef-tui": "workspace:*",
		"@opentelemetry/sdk-trace-base": "^1.30.1",
		"@opentelemetry/sdk-trace-node": "^2.7.1",
		"chalk": "^5.6.2",
		"jiti": "^2.7.0",
		"pino": "^10.3.1",
		"update-notifier": "7.3.1",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@libsql/client": "^0.17.4",
		"@napi-rs/canvas": "^1.0.0",
		"@types/node": "^24.3.0",
		"@types/pino": "^7.0.4",
		"eslint-plugin-boundaries": "^6.0.2",
		"node-pty": "^1.1.0",
		"strip-ansi": "^7.2.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.2",
		"vitest": "^4.1.6"
	},
	"keywords": [
		"agent",
		"runner",
		"cli"
	],
	"author": "Daniel Popsuevich",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
