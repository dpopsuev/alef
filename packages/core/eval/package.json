{
  "name": "@dpopsuev/alef-eval",
  "version": "0.0.2",
  "description": "Evaluation harness for Alef agents \u2014 OTel span collection, RunMetrics, Pi-parsable reports",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "test": "vitest --run"
  },
  "dependencies": {
    "@dpopsuev/alef-tool-fs": "workspace:*",
    "@dpopsuev/alef-tool-shell": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/alef-ai": "workspace:*",
    "@dpopsuev/alef-reasoner": "workspace:*",
    "@dpopsuev/alef-engine": "workspace:*",
    "@dpopsuev/alef-testkit": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "agent",
    "eval",
    "evaluation",
    "harness",
    "otel"
  ],
  "author": "Daniel Popsuevich",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "core",
    "entry": "./src/index.ts"
  }
}
