{
  "name": "@dpopsuev/alef-kernel",
  "version": "0.0.2",
  "description": "Canonical EDA bus, framework, and port registry for Alef organs",
  "type": "module",
  "main": "./src/adapter.ts",
  "types": "./dist/adapter.d.ts",
  "exports": {
    "./adapter": {
      "source": "./src/adapter.ts",
      "import": "./src/adapter.ts",
      "default": "./src/adapter.ts"
    },
    "./bus": {
      "source": "./src/bus.ts",
      "import": "./src/bus.ts",
      "default": "./src/bus.ts"
    },
    "./log": {
      "source": "./src/log.ts",
      "import": "./src/log.ts",
      "default": "./src/log.ts"
    },
    "./pipeline": {
      "source": "./src/pipeline.ts",
      "import": "./src/pipeline.ts",
      "default": "./src/pipeline.ts"
    },
    "./contributions": {
      "source": "./src/adapter/contributions.ts",
      "import": "./src/adapter/contributions.ts",
      "default": "./src/adapter/contributions.ts"
    },
    "./ui": {
      "source": "./src/adapter/ui.ts",
      "import": "./src/adapter/ui.ts",
      "default": "./src/adapter/ui.ts"
    },
    "./errors": {
      "source": "./src/shared/errors.ts",
      "import": "./src/shared/errors.ts",
      "default": "./src/shared/errors.ts"
    },
    "./execution": {
      "source": "./src/shared/execution.ts",
      "import": "./src/shared/execution.ts",
      "default": "./src/shared/execution.ts"
    },
    "./reconciliation": {
      "source": "./src/shared/reconciliation.ts",
      "import": "./src/shared/reconciliation.ts",
      "default": "./src/shared/reconciliation.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "ajv": "^8.20.0",
    "zod": "^4.4.3"
  },
  "keywords": [
    "agent",
    "nerve",
    "eda",
    "event-spine",
    "contracts"
  ],
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/nerve"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "core",
    "entry": "./src/adapter.ts"
  }
}
