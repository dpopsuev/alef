{
  "name": "@dpopsuev/alef-reasoner",
  "version": "0.0.2",
  "description": "LLM reasoner \u2014 tool_choice: any, routes tool calls as Motor events",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./events": "./src/events.ts",
    "./tool-events": "./src/tool-events.ts",
    "./tool-dispatch": "./src/tool-dispatch.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -b tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "llm",
    "nerve",
    "eda"
  ],
  "author": "Daniel Popsuevich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/core/reasoner"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@dpopsuev/alef-ai": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*",
    "@opentelemetry/api": "^1.9.1"
  },
  "devDependencies": {
    "@dpopsuev/alef-testkit": "workspace:*",
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "core",
    "entry": "./src/index.ts"
  }
}
