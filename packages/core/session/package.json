{
  "name": "@dpopsuev/alef-session",
  "version": "0.0.2",
  "description": "Session storage, context window assembly, and the Session interface for Alef agents",
  "type": "module",
  "main": "./src/contracts/session.ts",
  "types": "./dist/contracts/session.d.ts",
  "exports": {
    "./contracts": {
      "types": "./dist/contracts/session.d.ts",
      "default": "./src/contracts/session.ts"
    },
    "./storage": {
      "types": "./dist/contracts/storage.d.ts",
      "default": "./src/contracts/storage.ts"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "default": "./src/store.ts"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "default": "./src/agent.ts"
    },
    "./context": {
      "types": "./src/context/index.ts",
      "default": "./src/context/index.ts"
    },
    "./compaction": {
      "types": "./src/context/compaction.ts",
      "default": "./src/context/compaction.ts"
    },
    "./summarizer": {
      "types": "./src/context/summarizer.ts",
      "default": "./src/context/summarizer.ts"
    },
    "./title": {
      "types": "./src/context/title.ts",
      "default": "./src/context/title.ts"
    },
    "./scoring": {
      "types": "./src/context/scoring.ts",
      "default": "./src/context/scoring.ts"
    },
    "./projector": {
      "types": "./src/context/projector.ts",
      "default": "./src/context/projector.ts"
    },
    "./metadata": {
      "types": "./src/context/metadata.ts",
      "default": "./src/context/metadata.ts"
    },
    "./context/offloader": {
      "types": "./src/context/offloader.ts",
      "default": "./src/context/offloader.ts"
    },
    "./tracing": {
      "types": "./dist/tracing/index.d.ts",
      "default": "./src/tracing/index.ts"
    },
    "./replay": {
      "types": "./dist/tracing/replayer.d.ts",
      "default": "./src/tracing/replayer.ts"
    },
    "./token-telemetry": {
      "types": "./dist/token-telemetry.d.ts",
      "default": "./src/token-telemetry.ts"
    },
    "./token-query": {
      "types": "./dist/token-query.d.ts",
      "default": "./src/token-query.ts"
    },
    "./redact": {
      "types": "./dist/redact.d.ts",
      "default": "./src/redact.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -b tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@dpopsuev/alef-kernel": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/session"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "core",
    "entry": "./src/contracts/session.ts"
  }
}
