{
  "name": "@dpopsuev/alef-session",
  "version": "0.0.2",
  "description": "Session storage, context window assembly, and the Session interface for Alef agents",
  "type": "module",
  "main": "./src/contracts/session.ts",
  "types": "./dist/contracts/session.d.ts",
  "exports": {
    "./contracts": "./src/contracts/session.ts",
    "./storage": "./src/contracts/storage.ts",
    "./store": "./src/store.ts",
    "./agent": "./src/agent.ts",
    "./context": "./src/context/index.ts",
    "./compaction": "./src/context/compaction.ts",
    "./summarizer": "./src/context/summarizer.ts",
    "./scoring": "./src/context/scoring.ts",
    "./tracing": "./src/tracing/index.ts",
    "./replay": "./src/tracing/replayer.ts",
    "./redact": "./src/redact.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@dpopsuev/alef-ai": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/session"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "core",
    "entry": "./src/contracts/session.ts"
  }
}
