{
  "name": "@dpopsuev/alef-storage",
  "version": "0.0.2",
  "description": "SQLite-backed storage layer for Alef agent state (sessions, events, discourse, auth)",
  "type": "module",
  "main": "./src/interfaces.ts",
  "types": "./dist/interfaces.d.ts",
  "exports": {
    ".": "./src/interfaces.ts",
    "./factory": "./src/factory.ts",
    "./keyring": "./src/keyring.ts",
    "./memory": "./src/memory/session.ts",
    "./sqlite/database": "./src/sqlite/database.ts",
    "./sqlite/session": "./src/sqlite/session.ts",
    "./sqlite/event-load": "./src/sqlite/event-load.ts",
    "./sqlite/size-stats": "./src/sqlite/size-stats.ts",
    "./sqlite/schema": "./src/sqlite/schema.ts",
    "./sqlite/summary": "./src/sqlite/summary.ts",
    "./sqlite/auth": "./src/sqlite/auth.ts",
    "./sqlite/daemon": "./src/sqlite/daemon.ts",
    "./sqlite/migrations": "./src/sqlite/migrations.ts",
    "./sqlite/span-exporter": "./src/sqlite/span-exporter.ts",
    "./service": "./src/service.ts",
    "./testing/synthetic-sessions": "./test/helpers/synthetic-sessions.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -b tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@dpopsuev/alef-foundry": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/alef-supervisor": "workspace:*",
    "@dpopsuev/alef-session": "workspace:*",
    "@opentelemetry/core": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@libsql/client": "^0.17.4",
    "@napi-rs/keyring": "1.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "author": "Daniel Popsuevich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/storage"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "core",
    "entry": "./src/interfaces.ts"
  }
}
