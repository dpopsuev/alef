{
  "name": "@dpopsuev/alef-testkit",
  "version": "0.0.2",
  "description": "Test doubles and bus event recorders for the Alef nerve/organ system",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./adapter-contract": "./src/adapter-contract.ts",
    "./adapter-harness": "./src/adapter-harness.ts",
    "./bdd": "./src/bdd.ts",
    "./blueprint-gauntlet": "./src/blueprint-gauntlet.ts",
    "./blueprint-harness": "./src/blueprint-harness.ts",
    "./bus-fixture": "./src/bus-fixture.ts",
    "./bus-recorder": "./src/bus-event-recorder.ts",
    "./e2e": "./src/e2e-session.ts",
    "./memory-store": "./src/in-memory-session-store.ts",
    "./mock-reasoner": "./src/mock-reasoner.ts",
    "./organ": "./src/organ.ts",
    "./script": "./src/script.ts",
    "./scripted-reasoner": "./src/scripted-reasoner.ts",
    "./stub-adapter": "./src/stub-adapter.ts",
    "./turn-driver": "./src/turn-driver.ts",
    "./vitest-config": "./src/vitest-config.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "testkit",
    "mock",
    "nerve",
    "eda"
  ],
  "author": "Daniel Popsuevich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/testkit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@dpopsuev/alef-blueprint": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/alef-ai": "workspace:*",
    "@dpopsuev/alef-reasoner": "workspace:*",
    "@dpopsuev/alef-engine": "workspace:*",
    "@dpopsuev/alef-session": "workspace:*",
    "vite-tsconfig-paths": "*"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.5.0",
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "core",
    "entry": "./src/index.ts"
  }
}
