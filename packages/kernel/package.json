{
  "name": "@dpopsuev/alef-kernel",
  "version": "0.0.1",
  "description": "Canonical EDA bus, framework, and port registry for Alef organs",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapter": { "source": "./src/facade-adapter.ts", "import": "./src/facade-adapter.ts", "default": "./src/facade-adapter.ts" },
    "./bus": { "source": "./src/facade-bus.ts", "import": "./src/facade-bus.ts", "default": "./src/facade-bus.ts" },
    "./log": { "source": "./src/facade-log.ts", "import": "./src/facade-log.ts", "default": "./src/facade-log.ts" },
    "./pipeline": { "source": "./src/facade-pipeline.ts", "import": "./src/facade-pipeline.ts", "default": "./src/facade-pipeline.ts" },
    "./errors": { "source": "./src/facade-errors.ts", "import": "./src/facade-errors.ts", "default": "./src/facade-errors.ts" },
    "./reconciliation": { "source": "./src/reconciliation.ts", "import": "./src/reconciliation.ts", "default": "./src/reconciliation.ts" }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.42",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "ajv": "^8.20.0",
    "zod": "^4.4.3"
  },
  "keywords": [
    "agent",
    "nerve",
    "eda",
    "event-spine",
    "contracts"
  ],
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/nerve"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  }
}
