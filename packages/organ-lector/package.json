{
	"name": "@dpopsuev/alef-organ-lector",
	"version": "0.0.1",
	"description": "Lector organ — unified fs + symbol intelligence with block caching",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@dpopsuev/alef-spine": "^0.0.1"
	},
	"keywords": ["agent", "organ", "lector", "lsp", "tree-sitter", "symbols"],
	"author": "Daniel Popsuevich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dpopsuev/alef.git",
		"directory": "packages/organ-lector"
	},
	"engines": { "node": ">=20.0.0" },
	"devDependencies": {
		"@types/node": "^24.3.0",
		"shx": "^0.4.0",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	}
}
