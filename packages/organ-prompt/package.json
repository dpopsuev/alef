{
  "name": "@dpopsuev/alef-organ-prompt",
  "version": "0.0.1",
  "description": "Directive system and system-prompt assembly for Alef",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@dpopsuev/alef-spine": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2"
  },
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/organ-prompt"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
