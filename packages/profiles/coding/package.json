{
  "name": "@dpopsuev/alef-coding-agent",
  "version": "0.0.2",
  "description": "The default Alef coding agent blueprint. This package IS the SBOM \u2014 dependencies are the organ manifest.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./blueprint": "./blueprint.yaml"
  },
  "scripts": {
    "test": "vitest --run"
  },
  "dependencies": {
    "@dpopsuev/alef-tool-agent": "workspace:*",
    "@dpopsuev/alef-tool-code-intel": "workspace:*",
    "@dpopsuev/alef-tool-factory": "workspace:*",
    "@dpopsuev/alef-tool-fs": "workspace:*",
    "@dpopsuev/alef-tool-nodesh": "workspace:*",
    "@dpopsuev/alef-tool-shell": "workspace:*",
    "@dpopsuev/alef-tool-skills": "workspace:*",
    "@dpopsuev/alef-tool-web": "workspace:*",
    "@dpopsuev/alef-blueprint": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/alef-llm": "workspace:*",
    "@dpopsuev/alef-runtime": "workspace:*",
    "@dpopsuev/alef-session": "workspace:*"
  },
  "devDependencies": {
    "@dpopsuev/alef-eval": "workspace:*",
    "@dpopsuev/alef-reasoner": "workspace:*",
    "@dpopsuev/alef-testkit": "workspace:*",
    "@types/node": "^24.3.0",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "blueprint",
    "entry": "./src/index.ts"
  }
}
