    "@dpopsuev/alef-adapter-nodesh": "workspace:*",
    "@dpopsuev/alef-adapter-shell": "workspace:*",
    "@dpopsuev/alef-adapter-skills": "workspace:*",
    "@dpopsuev/alef-adapter-web": "workspace:*",
