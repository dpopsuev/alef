{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"target": "ES2024",
		"paths": {
			"@dpopsuev/alef-agent-blueprint": [
				"../blueprint/src/index.ts"
			],
			"@dpopsuev/alef-agent-blueprint/*": [
				"../blueprint/src/*.ts"
			],
			"@dpopsuev/alef-agent-core": [
				"../agent/src/index.ts"
			],
			"@dpopsuev/alef-ai": [
				"../ai/src/index.ts"
			],
			"@dpopsuev/alef-ai/*": [
				"../ai/src/*"
			],
			"@dpopsuev/alef-corpus": [
				"../corpus/src/index.ts"
			],
			"@dpopsuev/alef-kernel": [
				"../kernel/src/index.ts"
			],
			"@dpopsuev/alef-organ-dialog": [
				"../organ-dialog/src/index.ts"
			],
			"@dpopsuev/alef-organ-router": [
				"../organ-router/src/index.ts"
			],
			"@dpopsuev/alef-organ-fs": [
				"../organ-fs/src/index.ts"
			],
			"@dpopsuev/alef-organ-lector": [
				"../organ-lector/src/index.ts"
			],
			"@dpopsuev/alef-tui": [
				"../tui/src/index.ts"
			],
			"@dpopsuev/alef-tui/*": [
				"../tui/src/*"
			],
			"@dpopsuev/alef-organ-nodesh": [
				"../organ-nodesh/src/index.ts"
			],
			"@dpopsuev/alef-organ-orchestration": [
				"../organ-orchestration/src/index.ts"
			],
			"@dpopsuev/alef-organ-web": [
				"../organ-web/src/index.ts"
			],
			"@dpopsuev/alef-organ-delegate": [
				"../organ-delegate/src/index.ts"
			],
			"@dpopsuev/alef-organ-eval": [
				"../organ-eval/src/index.ts"
			],
			"@dpopsuev/alef-organ-shell": [
				"../organ-shell/src/index.ts"
			],
			"@dpopsuev/alef-organ-llm": [
				"../organ-llm/src/index.ts"
			],
			"@dpopsuev/alef-organ-prompt": [
				"../organ-prompt/src/index.ts"
			],
			"@dpopsuev/alef-session": [
				"../session/src/index.ts"
			],
			"@dpopsuev/alef-organ-memory": [
				"../organ-memory/src/index.ts"
			],
			"@dpopsuev/alef-testkit": [
				"../testkit/src/index.ts"
			],
			"@dpopsuev/alef-testkit/*": [
				"../testkit/src/*.ts"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	]
}
