{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"target": "ES2024",
		"paths": {
			"@dpopsuev/alef-agent-blueprint": [
				"../blueprint/src/index.ts"
			],
			"@dpopsuev/alef-agent-blueprint/*": [
				"../blueprint/src/*.ts"
			],
			"@dpopsuev/alef-llm": [
				"../ai/src/index.ts"
			],
			"@dpopsuev/alef-llm/*": [
				"../ai/src/*"
			],
			"@dpopsuev/alef-runtime": [
				"../runtime/src/index.ts"
			],
			"@dpopsuev/alef-kernel": [
				"../kernel/src/index.ts"
			],
			"@dpopsuev/alef-gateway": [
				"../gateway/src/index.ts"
			],
			"@dpopsuev/alef-adapter-fs": [
				"../adapter-fs/src/index.ts"
			],
			"@dpopsuev/alef-adapter-code-intel": [
				"../adapter-code-intel/src/index.ts"
			],
			"@dpopsuev/alef-tui": [
				"../tui/src/index.ts"
			],
			"@dpopsuev/alef-tui/*": [
				"../tui/src/*"
			],
			"@dpopsuev/alef-adapter-nodesh": [
				"../adapter-nodesh/src/index.ts"
			],
			"@dpopsuev/alef-adapter-agent": [
				"../adapter-agent/src/index.ts"
			],
			"@dpopsuev/alef-adapter-web": [
				"../adapter-web/src/index.ts"
			],
			"@dpopsuev/alef-adapter-eval": [
				"../adapter-eval/src/index.ts"
			],
			"@dpopsuev/alef-adapter-shell": [
				"../adapter-shell/src/index.ts"
			],
			"@dpopsuev/alef-reasoner": [
				"../reasoner/src/index.ts"
			],
			"@dpopsuev/alef-session": [
				"../session/src/index.ts"
			],
			"@dpopsuev/alef-testkit": [
				"../testkit/src/index.ts"
			],
			"@dpopsuev/alef-testkit/*": [
				"../testkit/src/*.ts"
			],
			"@dpopsuev/alef-coding-agent": [
				"../alef-coding-agent/src/index.ts"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	]
}
