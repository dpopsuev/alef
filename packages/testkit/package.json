{
  "name": "@dpopsuev/alef-testkit",
  "version": "0.0.1",
  "description": "Test doubles and bus event recorders for the Alef nerve/organ system",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./bdd": {
      "source": "./src/bdd.ts",
      "types": "./dist/bdd.d.ts",
      "import": "./src/bdd.ts"
    },
    "./organ": {
      "source": "./src/organ.ts",
      "types": "./dist/organ.d.ts",
      "import": "./src/organ.ts"
    },
    "./vitest-config": {
      "source": "./src/vitest-config.ts",
      "types": "./dist/vitest-config.d.ts",
      "import": "./src/vitest-config.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "testkit",
    "mock",
    "nerve",
    "eda"
  ],
  "author": "Daniel Popsuevich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/testkit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@dpopsuev/alef-agent-blueprint": "^0.0.1",
    "@dpopsuev/alef-llm": "^0.0.1",
    "@dpopsuev/alef-runtime": "^0.0.1",
    "@dpopsuev/alef-reasoner": "^0.0.1",
    "@dpopsuev/alef-kernel": "^0.0.1",
    "vite-tsconfig-paths": "*"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.5.0",
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  }
}
