{
  "name": "@dpopsuev/alef-tool-code-intel",
  "version": "0.0.2",
  "description": "Code Intelligence adapter — unified fs + symbol intelligence with block caching",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@dpopsuev/alef-foundry": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/alef-supervisor": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "glob": "^13.0.6",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript-language-server": "^5.2.0",
    "zod": "^4.4.3"
  },
  "keywords": [
    "agent",
    "code-intel",
    "lsp",
    "tree-sitter",
    "symbols"
  ],
  "author": "Daniel Popsuevich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/tools/code-intel"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@dpopsuev/alef-testkit": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "tool",
    "entry": "./src/index.ts"
  }
}
