{
  "name": "@dpopsuev/alef-tool-dot",
  "version": "0.0.2",
  "description": "Dot-in-circle game tool — remote plant client for reconcile E2E episodes",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest --run",
    "clean": "shx rm -rf dist",
    "game": "npx tsx src/game-server-main.ts"
  },
  "dependencies": {
    "@dpopsuev/alef-kernel": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dpopsuev/alef-blueprint": "workspace:*",
    "@dpopsuev/alef-eval": "workspace:*",
    "@dpopsuev/alef-testkit": "workspace:*",
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "tool",
    "entry": "./src/index.ts"
  }
}
