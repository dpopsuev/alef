{
  "name": "@dpopsuev/alef-tool-eval",
  "version": "0.0.2",
  "description": "Eval adapter \u2014 send prompts to a child Alef endpoint and score responses with structural validators and LLM-as-judge",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "npx tsc -p tsconfig.build.json",
    "test": "vitest --run",
    "clean": "shx rm -rf dist"
  },
  "dependencies": {
    "@dpopsuev/alef-ai": "workspace:*",
    "@dpopsuev/alef-foundry": "workspace:*",
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/alef-supervisor": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dpopsuev/alef-testkit": "workspace:*",
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "tool",
    "entry": "./src/index.ts"
  }
}
