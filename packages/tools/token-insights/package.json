{
  "name": "@dpopsuev/alef-tool-token-insights",
  "version": "0.0.1",
  "description": "Token usage insights adapter — query and analyze LLM token consumption",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "tokens",
    "telemetry"
  ],
  "dependencies": {
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/alef-session": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/tools/token-insights"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "alef": {
    "type": "adapter",
    "entry": "./src/adapter.ts",
    "adapterName": "token-insights"
  }
}
