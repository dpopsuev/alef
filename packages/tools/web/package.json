{
  "name": "@dpopsuev/alef-tool-web",
  "version": "0.0.2",
  "description": "Web organ \u2014 fetch pages and search the web. Supports Brave, Tavily, Exa, and DuckDuckGo.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "npx tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "organ",
    "web",
    "fetch",
    "search",
    "html"
  ],
  "author": "Daniel Popsuevich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpopsuev/alef.git",
    "directory": "packages/organ-web"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@dpopsuev/alef-kernel": "workspace:*",
    "@dpopsuev/web-spider": "^0.10.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dpopsuev/alef-testkit": "workspace:*",
    "@types/node": "^24.3.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
