		"packages/*/*/src/**/*",
		"packages/*/*/test/**/*",
		"packages/agent/src/**/*",
		"packages/agent/test/**/*",
		"vitest.shims.ts"
	],
	"exclude": [
		"packages/ui/web/**/*",
		"**/dist/**"
