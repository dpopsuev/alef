{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@dpopsuev/alef-ai": ["./packages/ai/src/index.ts"],
			"@dpopsuev/alef-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@dpopsuev/alef-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@dpopsuev/alef-ai/dist/*": ["./packages/ai/src/*"],
			"@dpopsuev/alef-agent-core": ["./packages/agent/src/index.ts"],
			"@dpopsuev/alef-agent-core/*": ["./packages/agent/src/*"],
			"@dpopsuev/alef-agent-blueprint": ["./packages/blueprint/src/index.ts"],
			"@dpopsuev/alef-agent-blueprint/*": ["./packages/blueprint/src/*.ts"],
			"@dpopsuev/alef-agent-runtime": ["./packages/runtime/src/index.ts"],
			"@dpopsuev/alef-agent-runtime/*": ["./packages/runtime/src/*.ts"],
			"@dpopsuev/alef-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@dpopsuev/alef-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@dpopsuev/alef-coding-agent/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@dpopsuev/alef-tui": ["./packages/tui/src/index.ts"],
			"@dpopsuev/alef-tui/*": ["./packages/tui/src/*"],
			"@dpopsuev/alef-web-ui": ["./packages/web-ui/src/index.ts"],
			"@dpopsuev/alef-web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
